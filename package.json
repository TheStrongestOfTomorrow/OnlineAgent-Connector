{
  "name": "online-agent",
  "version": "2.1.1",
  "description": "Cross-platform Terminal CLI + TUI that hosts a local server so AI agents can connect via a pairing code and respond directly in your terminal. Works on Windows, Linux, macOS, and Android (Termux).",
  "main": "src/index.js",
  "bin": {
    "online-agent": "bin/cli.js",
    "oac": "bin/cli.js"
  },
  "scripts": {
    "start": "node bin/cli.js",
    "tui": "node bin/cli.js tui",
    "oac": "node bin/cli.js",
    "test": "node tests/basic.test.js && node tests/e2e.test.js",
    "prepublishOnly": "node bin/cli.js --version"
  },
  "keywords": [
    "cli",
    "ai-agent",
    "local-server",
    "websocket",
    "cross-platform",
    "termux",
    "remote-shell",
    "agent-connector",
    "mcp",
    "agent-tool",
    "online-agent",
    "tui",
    "json-rpc"
  ],
  "author": "TheStrongestOfTomorrow",
  "license": "MIT",
  "homepage": "https://github.com/TheStrongestOfTomorrow/OnlineAgent-Connector#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TheStrongestOfTomorrow/OnlineAgent-Connector.git"
  },
  "bugs": {
    "url": "https://github.com/TheStrongestOfTomorrow/OnlineAgent-Connector/issues"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "os": [
    "linux",
    "darwin",
    "win32",
    "android",
    "freebsd",
    "openbsd"
  ],
  "cpu": [
    "x64",
    "arm64",
    "arm",
    "ia32",
    "mips",
    "ppc64"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "files": [
    "bin/",
    "src/",
    "examples/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "//": "CONTRIBUTING.md is intentionally excluded from the npm package — it's for repo contributors only, not end users.",
  "dependencies": {
    "blessed": "^0.1.81",
    "commander": "^12.1.0",
    "ws": "^8.18.0"
  }
}
